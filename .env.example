# Copy to .env and adjust. All values are optional — sensible defaults are used.

# Secret key for signing sessions. If unset, a persistent one is generated
# automatically in instance/.secret_key
# SECRET_KEY=change-me-to-a-long-random-string

# Where the SQLite database lives
# CHITRALAHAR_DATABASE=instance/chitralahar.db

# Max upload size per request, in megabytes. Unset/0 = unlimited.
# NOTE: a multi-file batch upload counts as ONE request, so a low cap blocks
# large batches. Set a generous value on public servers and keep Apache's
# LimitRequestBody in sync.
# CHITRALAHAR_MAX_UPLOAD_MB=200

# Set to 1 when serving over HTTPS so the admin session cookie is marked Secure.
# CHITRALAHAR_HTTPS=1

# Reject images whose pixel count exceeds this (decompression-bomb guard).
# CHITRALAHAR_MAX_IMAGE_PIXELS=64000000
